# Render build environment variable — REQUIRED for production
# Your InfinityFree backend URL (where you uploaded the backend/ folder)
# Example: https://fraudshield.infinityfreeapp.com/backend
VITE_API_BASE_URL=https://YOUR-SITE.infinityfreeapp.com/backend

# Optional: Flask fraud API (leave empty to use built-in JS mock)
# VITE_FLASK_API_URL=
